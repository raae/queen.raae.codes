---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PageSection from "../components/PageSection.astro";
---

<BaseLayout title="Page Not Found" description="This page doesn't exist — but the treasure is elsewhere!">
  <SiteHeader />
  <PageSection>
    <div class="flex flex-col items-center justify-center py-16 text-center">
      <p class="text-6xl mb-6">🗺️</p>
      <h1
        class="text-4xl md:text-5xl font-bold mb-4"
        style="font-family: var(--font-label);"
      >
        X Marks the Wrong Spot
      </h1>
      <p class="text-lg text-brown-700 mb-2 max-w-md" style="font-family: var(--font-body);">
        This page has sailed off the map. The treasure you're looking for might be elsewhere&hellip;
      </p>

      <hr class="ornamental-hr my-8 w-full max-w-xs border-none text-center text-amber-500 text-xl tracking-[0.75rem]"
        style="height: auto;"
      />

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/"
          class="inline-block px-6 py-3 bg-plum-700 text-white rounded font-semibold no-underline hover:bg-plum-800 transition-colors"
          style="font-family: var(--font-label);"
        >
          Back to Shore 👑
        </a>
        <a
          href="/search/"
          class="inline-block px-6 py-3 border border-plum-400 text-plum-600 rounded font-semibold no-underline hover:bg-plum-50 transition-colors"
          style="font-family: var(--font-label);"
        >
          Search for Treasure 🔍
        </a>
      </div>
    </div>
  </PageSection>
</BaseLayout>

<style>
  .ornamental-hr::after {
    content: "⚜  👑  ⚜";
  }
</style>
