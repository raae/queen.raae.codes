---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PageSection from "../components/PageSection.astro";
import PageSectionHeader from "../components/PageSectionHeader.astro";
---

<BaseLayout title="Page Not Found" description="This page doesn't exist — but the treasure is elsewhere!">
  <SiteHeader />
  <main>
    <PageSection component="header">
      <PageSectionHeader badge="404" title="X Marks the Wrong Spot" lead="This page has sailed off the map. The treasure you're looking for might be elsewhere&hellip;" hLevel={1} />
    </PageSection>

    <PageSection>
      <div class="flex flex-col sm:flex-row gap-3 max-w-md">
        <a
          href="/"
          class="inline-flex items-center justify-center px-4 py-2 border-2 border-solid border-plum-500 bg-plum-500 text-white text-sm font-semibold no-underline hover:bg-plum-800 hover:border-plum-800 transition focus:outline-hidden focus:ring-2 focus:ring-amber-500 focus:ring-offset-2"
          style="font-family: var(--font-label);"
        >
          Back to shore 👑
        </a>
        <a
          href="/search/"
          class="inline-flex items-center justify-center px-4 py-2 border-2 border-solid border-plum-500 bg-transparent text-plum-500 text-sm font-semibold no-underline hover:bg-plum-50 transition focus:outline-hidden focus:ring-2 focus:ring-amber-500 focus:ring-offset-2"
          style="font-family: var(--font-label);"
        >
          Search for treasure 🔍
        </a>
      </div>
    </PageSection>
  </main>
</BaseLayout>
